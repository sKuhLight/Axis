# Override the ForgeFX API base (default: /api, proxied to localhost:5056 in dev)
# VITE_FORGEFX_BASE=http://localhost:5056

# ── Axis Cloud Remote (web build only) ──
# Build the app in remote mode (no local ForgeFX; drives the user's PC over the relay). Set for the
# axisapp.live build; leave unset for the desktop/Electron build.
# VITE_AXIS_REMOTE=1
# Supabase project — the ANON (publishable) key is client-safe (RLS protects data); it ends up in the
# built bundle by design. Provide via env/CI at build time; NEVER commit a real .env. The service-role
# key must NEVER appear here or in any client.
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=<publishable-anon-key>
