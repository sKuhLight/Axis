{
  "name": "axis",
  "version": "0.9.4-beta",
  "description": "Axis — editor for Fractal devices (FM3), bundling the ForgeFX engine",
  "author": {
    "name": "sKuhLight",
    "email": "sKuhLight@users.noreply.github.com"
  },
  "homepage": "https://github.com/sKuhLight/Axis",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite dev",
    "dev:remote": "VITE_AXIS_REMOTE=1 vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "electron:dev": "ELECTRON_DEV=1 electron .",
    "desktop:build": "VITE_FORGEFX_BASE= vite build && electron-builder",
    "build:mobile": "VITE_AXIS_MOBILE=1 VITE_OTA_MANIFEST_URL=https://github.com/sKuhLight/Axis/releases/download/ota-ios-latest/latest-ios.json vite build",
    "mobile:sync": "npm run build:mobile && cap sync ios",
    "test": "vitest run",
    "test:workbench-visual": "node scripts/workbench-visual-smoke.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capgo/capacitor-updater": "8.50.2",
    "@grafana/faro-web-sdk": "^2.8.1",
    "@orama/orama": "^3.1.18",
    "@supabase/supabase-js": "^2.110.0",
    "brotli-wasm": "^3.0.1",
    "electron-updater": "^6.3.9",
    "forgefx-server": "file:../ForgeFX/server",
    "js-sha256": "^0.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@capacitor/ios": "8.4.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "3.2.4"
  }
}
